<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/primary_gradient">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:title="@string/profile"
            app:titleTextColor="?attr/colorOnPrimary"
            app:titleCentered="true" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Profile Header -->
            <RelativeLayout
                android:layout_width="120dp"
                android:layout_height="120dp">
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_profile_image"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_centerInParent="true"
                    android:padding="4dp"
                    android:src="@drawable/ic_user"
                    android:background="@drawable/glass_background"
                    android:contentDescription="@string/profile"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="2dp" />
                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fab_edit_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentEnd="true"
                    android:src="@android:drawable/ic_menu_edit"
                    app:fabCustomSize="32dp"
                    app:maxImageSize="16dp"
                    app:tint="@color/primary"
                    android:contentDescription="Edit Profile" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tv_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/user_name"
                android:textColor="?attr/colorOnSurface"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_profile_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/user_email"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp" />

            <!-- Financial Score Badge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center_vertical"
                        android:src="@android:drawable/star_on"
                        app:tint="#FBBF24" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/financial_score_prefix"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/score_value"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Settings Sections -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/account_settings"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.FinIntelligence.GlassCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Item: Linked Accounts -->
                        <RelativeLayout
                            android:id="@+id/rl_linked_accounts"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"
                            android:padding="18dp">
                            <ImageView
                                android:id="@+id/icon_bank"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_bank"
                                app:tint="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:layout_toEndOf="@id/icon_bank"
                                android:layout_toStartOf="@+id/chevron1"
                                android:text="@string/linked_bank_accounts"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="16sp" />
                            <ImageView
                                android:id="@+id/chevron1"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/text_secondary" />
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="?attr/colorOutlineVariant" />

                        <!-- Item: Security -->
                        <RelativeLayout
                            android:id="@+id/rl_security"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"
                            android:padding="18dp">
                            <ImageView
                                android:id="@+id/icon_lock"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_lock"
                                app:tint="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:layout_toEndOf="@id/icon_lock"
                                android:layout_toStartOf="@+id/chevron2"
                                android:text="@string/security_privacy"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="16sp" />
                            <ImageView
                                android:id="@+id/chevron2"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/text_secondary" />
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="?attr/colorOutlineVariant" />

                        <!-- Item: Monthly Budget -->
                        <RelativeLayout
                            android:id="@+id/rl_monthly_budget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"
                            android:padding="18dp">
                            <ImageView
                                android:id="@+id/icon_budget"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_bank"
                                app:tint="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:layout_toEndOf="@id/icon_budget"
                                android:layout_toStartOf="@+id/tv_current_budget"
                                android:text="Monthly Budget"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="16sp" />
                            <TextView
                                android:id="@+id/tv_current_budget"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginEnd="8dp"
                                android:layout_toStartOf="@+id/chevron_budget"
                                android:text="Rs 0"
                                android:textColor="?attr/colorPrimary"
                                android:textStyle="bold" />
                            <ImageView
                                android:id="@+id/chevron_budget"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="@color/text_secondary" />
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="?attr/colorOutlineVariant" />

                        <!-- Item: Biometric Security -->
                        <RelativeLayout
                            android:id="@+id/rl_biometric"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="18dp">
                            <ImageView
                                android:id="@+id/icon_fingerprint"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_lock_idle_lock"
                                app:tint="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:layout_toEndOf="@id/icon_fingerprint"
                                android:layout_toStartOf="@+id/switch_biometric"
                                android:text="Fingerprint Lock"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="16sp" />
                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/switch_biometric"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                app:thumbTint="?attr/colorSurface"
                                app:trackTint="?attr/colorPrimary" />
                        </RelativeLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="12dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/preferences"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.FinIntelligence.GlassCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="18dp">
                            <ImageView
                                android:id="@+id/icon_notif"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_notifications"
                                app:tint="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:layout_toEndOf="@id/icon_notif"
                                android:layout_toStartOf="@+id/switch_notifications"
                                android:text="@string/notifications"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="16sp" />
                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/switch_notifications"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:checked="true"
                                app:thumbTint="?attr/colorSurface"
                                app:trackTint="?attr/colorPrimary" />
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="?attr/colorOutlineVariant" />

                        <!-- Item: Dark Mode -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="18dp">
                            <ImageView
                                android:id="@+id/icon_dark_mode"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_menu_day"
                                app:tint="@color/primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:layout_toEndOf="@id/icon_dark_mode"
                                android:layout_toStartOf="@+id/switch_dark_mode"
                                android:text="Dark Mode"
                                android:textColor="?attr/colorOnSurface"
                                android:textSize="16sp" />
                            <com.google.android.material.materialswitch.MaterialSwitch
                                android:id="@+id/switch_dark_mode"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                app:thumbTint="?attr/colorSurface"
                                app:trackTint="?attr/colorPrimary" />
                        </RelativeLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginHorizontal="16dp"
                            android:background="?attr/colorOutlineVariant" />

                        <RelativeLayout
                            android:id="@+id/rl_logout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"
                            android:padding="18dp">
                            <ImageView
                                android:id="@+id/icon_logout"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_logout"
                                app:tint="#FFA7A7" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="16dp"
                                android:layout_toEndOf="@id/icon_logout"
                                android:text="@string/logout"
                                android:textColor="#FFA7A7"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </RelativeLayout>


                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>